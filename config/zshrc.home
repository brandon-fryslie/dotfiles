# nix via podman (no system volume required)
alias nix='podman run --rm -it -v "$(pwd):/workspace" -w /workspace nixos/nix nix'

# Uncomment to enable profiling
# zmodload zsh/zprof

export DOTFILES_DIR="$HOME/code/dotfiles"

# Run dotfiles migrations (lightweight, idempotent)
[[ -f "${DOTFILES_DIR}/migrations/run-migrations.sh" ]] && source "${DOTFILES_DIR}/migrations/run-migrations.sh"

# Automatically deduplicate PATH entries
typeset -U path

setopt share_history

# TODO: move this somewhere else, at minimum the helper fns
is_claude() { [[ -n "${CLAUDECODE}" ]] && return 0 || return 1 }
not_claude() { ! is_claude && return 0 || return 1 }

# Use full plugin set for human sessions
export RAD_PLUGINS_FILE=~/.rad-plugins
# Use default zgenom cache for human sessions
export ZGEN_INIT=~/.zgenom/sources/init.zsh

# Source base zshrc
source "${DOTFILES_DIR}/config/zshrc.base"

# Load p10k theme (skip for Claude since we don't need fancy prompts)
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# Add customizations below

# Local code configuration
export PROJECTS_DIR="$HOME/code"
export PROJECTS_DIRS=(~/projects ~/code)

# Python
export PATH="/usr/local/opt/python/libexec/bin:$PATH"

# ---

# Misc
alias e.="${VISUAL:-vi} ."
alias dog='pygmentize -g'
# Use e-prawn GitHub SSH identity for gh-driven git operations
alias gh='GIT_SSH_COMMAND="ssh -i ~/.ssh/id_ed25519_elton-prawn -o IdentitiesOnly=yes" command gh'

# Move to a rad-shell plugin
# Try finding the first ethernet adapter that has a valid ipv4 address
local-ip() {
  for i in `seq 0 10`; do
    res="$(/sbin/ifconfig en${i} | grep 'inet' | grep -v inet6 | awk '{print $2}')"
    [[ -n $res ]] && echo $res && return
  done
}


# what's this for?
PATH="$PATH:/opt/homebrew/opt/coreutils/libexec/gnubin:/usr/local/bin"

# SDKMAN
export SDKMAN_DIR="$HOME/.sdkman"
[[ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]] && source "$HOME/.sdkman/bin/sdkman-init.sh"

# pnpm — global bin dir holds pnpm-managed node + global package binaries
export PNPM_HOME="/Users/bmf/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) export PATH="$PNPM_HOME/bin:$PATH" ;;
esac
# pnpm end

alias venv-direnv="echo 'source .venv/bin/activate' >> .envrc && direnv allow"

# node is managed by pnpm (see pnpm block above); its bin dir is on PATH

export PATH="/usr/local/opt/gnu-sed/libexec/gnubin:$PATH"

# bun completions
[ -s "/Users/bmf/.bun/_bun" ] && source "/Users/bmf/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

export UV_PYTHON=3.12

# Final PATH deduplication (removes duplicates added by plugins/tools)
# This ensures PATH stays clean even when plugins add duplicate entries
typeset -U path

# Set up fzf key bindings and fuzzy completion
command -v fzf >/dev/null && source <(fzf --zsh)
command -v mcpi >/dev/null && eval "$(_MCPI_COMPLETE=zsh_source mcpi)"

# Java via sdkman; if absent, shim `java` to print how to install it
if [[ -x "$HOME/.sdkman/candidates/java/current/bin/java" ]]; then
  export JAVA_HOME="$HOME/.sdkman/candidates/java/current"
  export PATH="$JAVA_HOME/bin:$PATH"
else
  java() {
    print -r -- "java is not installed. Install via sdkman:
  curl -s \"https://get.sdkman.io\" | bash   # skip if sdkman already installed
  sdk install java"
    return 127
  }
fi

alias aclod="archgw cli-agent claude --path /Users/bmf/code/arch/demos/use_cases/claude_code_router"


export COLORTERM=truecolor

### zsh plugin manager
z() {
  local plugin="$1" repo="${plugin%@*}" branch="${plugin#*@}" dir="${HOME}/.zsh/p/${repo}" name="${repo:t}"; [[ "${branch}" == "${plugin}" ]] && branch=HEAD
  [[ -d "${dir}/.git" ]] || git clone -q --depth=1 ${branch!=HEAD:+--branch "${branch}"} "https://github.com/${repo}.git" "${dir}"
  fpath=("${dir}" "${dir}/completions" "${dir}/functions" $fpath); shift; (( "$#" )) && source "${^dir}/$@" || source "${dir}/${name}"{.plugin,}.zsh(N[1])
}


## proj2 - project navigator
export GOBIN=$HOME/.local/bin
# GOBIN and other user-local installs (lit, mcp, …) land in ~/.local/bin — put it on PATH
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.cargo/bin:$PATH"

# Added by Antigravity
export PATH="/Users/bmf/.antigravity/antigravity/bin:$PATH"

# opencode
export PATH=/Users/bmf/.opencode/bin:$PATH
alias zj="zellij attach -c main"
alias copp='copilot --yolo'

# tabtab source for electron-forge package
# uninstall by removing these lines or running `tabtab uninstall electron-forge`
[[ -f /Users/bmf/.local/share/fnm/node-versions/v24.13.0/installation/lib/node_modules/electron-forge/node_modules/tabtab/.completions/electron-forge.zsh ]] && . /Users/bmf/.local/share/fnm/node-versions/v24.13.0/installation/lib/node_modules/electron-forge/node_modules/tabtab/.completions/electron-forge.zsh

c1() {
  cc-jstream claude "$@"
}

c2() {
  cc-jstream -i claude "$@"
}
export NODE_EXTRA_CA_CERTS=~/cc-nerf-buster-ca.crt

prox() {
  set -a 2>/dev/null || true; source "/Users/bmf/Library/Application Support/com.proxyman.NSProxy/app-data/proxyman_env_automatic_setup.sh"; set +a 2>/dev/null || true
}