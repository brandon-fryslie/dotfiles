#!/usr/bin/env bash
set -euo pipefail

USAGE="tmux-talk — thin wrappers over tmux for agent-to-agent communication

Subcommands:
  list                           List all tmux panes with session:window.pane address and running command
  whoami                         Print this pane's tmux address (session:window.pane)
  send   <target> <message...>   Send a message to a pane, wrapped with From:/To-reply: envelope
  read-screen <target> [lines]   Capture pane content (default: 200 lines of scrollback)
  wait   <target> [timeout]      Poll until the Claude idle prompt appears (default: 120s)
  idle   <target>                Exit 0 if pane shows idle prompt, 1 otherwise

target format: session:window.pane  (e.g. work:0.0, research:editor.0)"

# [LAW:one-source-of-truth] single derivation for "what's my tmux address",
# consumed by both `whoami` and `send`. Total contract: prints address on
# stdout, or prints error on stderr and returns 1 — no empty-success state.
# [LAW:types-are-the-program] precondition is BOTH $TMUX (server attached)
# and $TMUX_PANE (which pane we're in) — without -t "$TMUX_PANE", tmux falls
# back to the current client's active pane, which may not be the invoking
# pane in multi-client setups.
derive_self_address() {
  if [[ -z "${TMUX:-}" || -z "${TMUX_PANE:-}" ]]; then
    echo "tmux-talk: not running inside tmux — \$TMUX/\$TMUX_PANE not set" >&2
    return 1
  fi
  tmux display-message -p -t "$TMUX_PANE" '#{session_name}:#{window_index}.#{pane_index}'
}

CMD="${1:-}"

case "$CMD" in

  list)
    tmux list-panes -a -F "#{session_name}:#{window_index}.#{pane_index}  cmd=#{pane_current_command}  title=#{pane_title}"
    ;;

  whoami)
    derive_self_address
    ;;

  send)
    TARGET="${2:-}"
    # Take every arg after the target as the message body so an unquoted
    # natural-language reply doesn't silently drop everything past the first
    # word. Bash positional slice avoids the shift+conditional dance.
    MESSAGE="${*:3}"
    if [[ -z "$TARGET" || -z "$MESSAGE" ]]; then
      echo "Usage: tmux-talk send <target> <message...>" >&2
      exit 1
    fi
    FROM=$(derive_self_address) || exit 1

    # [LAW:no-shared-mutable-globals] private buffer name so concurrent sends
    # can't clobber each other via tmux's global most-recent-buffer slot.
    # [LAW:single-enforcer] the EXIT trap owns the entire buffer lifecycle —
    # no -d on paste-buffer, no duplicate cleanup. "Buffer already gone" is
    # the success state for cleanup, so swallowing that one error class is
    # correct, not defensive.
    BUFFER="tmux-talk-$$"
    trap 'tmux delete-buffer -b "$BUFFER" 2>/dev/null || :' EXIT
    printf 'From: %s\n%s\nTo reply: Use /tmux-talk send %s <message...>' \
           "$FROM" "$MESSAGE" "$FROM" \
      | tmux load-buffer -b "$BUFFER" -
    tmux paste-buffer -b "$BUFFER" -t "$TARGET" -p
    sleep 1
    tmux send-keys -t "$TARGET" Enter
    ;;

  read-screen)
    TARGET="${2:-}"
    LINES="${3:-200}"
    if [[ -z "$TARGET" ]]; then
      echo "Usage: tmux-talk read-screen <target> [lines]" >&2
      exit 1
    fi
    tmux capture-pane -t "$TARGET" -p -S -"$LINES"
    ;;

  wait)
    TARGET="${2:-}"
    TIMEOUT="${3:-120}"
    if [[ -z "$TARGET" ]]; then
      echo "Usage: tmux-talk wait <target> [timeout]" >&2
      exit 1
    fi
    INTERVAL=2
    ELAPSED=0
    PREV=""
    while [ "$ELAPSED" -lt "$TIMEOUT" ]; do
      sleep "$INTERVAL"
      ELAPSED=$((ELAPSED + INTERVAL))
      CURRENT=$(tmux capture-pane -t "$TARGET" -p -S -50)
      if [ "$CURRENT" = "$PREV" ] && ! printf '%s' "$CURRENT" | grep -qF 'ing…'; then
        exit 0
      fi
      PREV="$CURRENT"
    done
    echo "tmux-talk wait: timed out after ${TIMEOUT}s waiting for idle prompt in '$TARGET'" >&2
    exit 1
    ;;

  idle)
    TARGET="${2:-}"
    if [[ -z "$TARGET" ]]; then
      echo "Usage: tmux-talk idle <target>" >&2
      exit 1
    fi
    CONTENT=$(tmux capture-pane -t "$TARGET" -p -S -10)
    if printf '%s' "$CONTENT" | grep -qF 'ing…'; then
      exit 1
    fi
    exit 0
    ;;

  *)
    echo "$USAGE" >&2
    exit 1
    ;;

esac
