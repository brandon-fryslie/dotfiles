#!/usr/bin/env bash
# message-in-a-bottle — schedule a delayed self-message into the current
# tmux pane. The launcher returns immediately; a detached worker resets the
# context (/clear or /compact) and pastes the message after a fixed delay.
#
# Modes:
#   launcher:  message-in-a-bottle <clear|compact> <message...>
#   worker:    message-in-a-bottle --worker <target> <reset> <msgfile>

set -euo pipefail

# [LAW:one-source-of-truth] the fixed delay lives here once; both the
# launcher's "in Ns" line and the worker's sleep read this same value. Not a
# consumer knob — it's tuned here if the agent-finish window ever changes.
BOTTLE_DELAY_SECONDS=15

# The reset is sent in an attempt/verify loop: type it, read the pane back,
# confirm it actually registered as a command (not queued as literal text),
# and only then is the message allowed to flow. This caps the attempts so a
# pane that genuinely cannot accept the reset can't loop forever.
MAX_RESET_ATTEMPTS=4
SETTLE=1.5

# [LAW:types-are-the-program] one discriminator at the entry; everything
# downstream operates on validated, typed inputs for exactly one mode.
if [[ "${1:-}" == "--worker" ]]; then
  MODE=worker
  shift
else
  MODE=launcher
fi

case "$MODE" in

  launcher)
    if [[ $# -lt 2 ]]; then
      cat >&2 <<'USAGE'
Usage: message-in-a-bottle <clear|compact> <message...>

  clear|compact  which context reset to fire before the message lands
  message        the rest of argv; slash command or plain text, multi-word ok

The message lands in the invoking tmux pane after a fixed delay. Must run inside tmux.
USAGE
      exit 2
    fi

    RESET="$1"; shift
    MESSAGE="$*"

    # [LAW:types-are-the-program] the reset is one of exactly two values;
    # constrain it at the boundary so the worker can never see an illegal
    # command. No downstream code re-checks — the input is typed from here on.
    [[ "$RESET" == clear || "$RESET" == compact ]] \
      || { echo "first arg must be 'clear' or 'compact' (got: $RESET)" >&2; exit 2; }

    # [LAW:no-defensive-null-guards] every precondition fails loudly at the
    # boundary — no silent defaulting that would let an empty bottle ship.
    [[ -n "$MESSAGE" ]] || { echo "message must not be empty" >&2; exit 2; }
    [[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]] \
      || { echo "not inside tmux (\$TMUX/\$TMUX_PANE unset)" >&2; exit 2; }

    # [LAW:one-source-of-truth] target derived from $TMUX_PANE via tmux
    # itself — never accepted as a flag; tmux is the authority.
    TARGET=$(tmux display-message -p -t "$TMUX_PANE" \
      '#{session_name}:#{window_index}.#{pane_index}')

    # [LAW:dataflow-not-control-flow] the message flows through a tempfile
    # as a value, bypassing every shell-quoting hazard between argv → worker
    # → tmux load-buffer. No escaping branches anywhere.
    MSGFILE=$(mktemp -t bottle-msg.XXXXXX)
    LOGFILE=""
    # [LAW:single-enforcer] one trap covers both tempfiles until the worker
    # is spawned; cleared right after `nohup` so the worker owns MSGFILE and
    # the launcher's "log: ..." line is the only reference to LOGFILE.
    # ${LOGFILE:+...} elides the arg entirely while LOGFILE is still empty —
    # avoids passing "" to rm, which GNU coreutils warns about.
    trap 'rm -f -- "$MSGFILE" ${LOGFILE:+"$LOGFILE"}' EXIT
    printf '%s' "$MESSAGE" > "$MSGFILE"

    # Resolve own path for both ./script and PATH-lookup invocations.
    # `$0` lacks a slash on PATH lookup, so dirname/pwd would yield $PWD
    # — wrong. `command -v` does PATH resolution; for paths containing
    # slashes it returns as-is.
    if [[ "$0" == */* ]]; then
      SELF_RAW="$0"
    else
      SELF_RAW=$(command -v -- "$0") \
        || { echo "cannot resolve own path from \$0=$0" >&2; exit 2; }
    fi
    SELF="$(cd "$(dirname "$SELF_RAW")" && pwd)/$(basename "$SELF_RAW")"

    # LOGFILE created just before the spawn — short lifetime minimizes the
    # window where a signal or freak `>>` failure could leave it behind,
    # and the EXIT trap above covers it as a backstop until we clear it.
    LOGFILE=$(mktemp -t bottle-log.XXXXXX)

    # nohup ignores SIGHUP, redirected stdio keeps nohup.out from spawning,
    # and the backgrounded child gets reparented to init when this shell
    # exits — `disown` would be belt-and-suspenders, but with `set -e` a
    # disown failure would fire the trap and yank MSGFILE out from under
    # the running worker. Leaving disown out closes that race entirely.
    nohup "$SELF" --worker "$TARGET" "$RESET" "$MSGFILE" \
      </dev/null >>"$LOGFILE" 2>&1 &
    trap - EXIT

    echo "bottle scheduled → $TARGET (/$RESET) in ${BOTTLE_DELAY_SECONDS}s (log: $LOGFILE)"
    ;;

  worker)
    if [[ $# -ne 3 ]]; then
      echo "internal error: worker expects exactly 3 args" >&2
      exit 2
    fi
    TARGET="$1"
    RESET="$2"
    MSGFILE="$3"

    # [LAW:single-enforcer] launcher owns input validation (RESET value,
    # MSGFILE existence) AND log destination (via nohup stdout redirect).
    # `--worker` is a non-interface, not a public entry point, so the worker
    # does not re-check — duplicating those checks would be drift-prone
    # ceremony for states that cannot occur via the documented call path.
    BUFFER="bottle-$$"

    # [LAW:single-enforcer] one trap owns cleanup of both the message file
    # and the tmux buffer; no scattered rm/delete-buffer calls elsewhere.
    trap 'rm -f "$MSGFILE"; tmux delete-buffer -b "$BUFFER" 2>/dev/null || :' EXIT

    log() { printf '[%s] %s\n' "$(date '+%H:%M:%S')" "$*"; }

    # [LAW:types-are-the-program] the reset value carries its own proof. Each
    # reset, once it actually RUNS as a command, leaves a signature on the pane
    # that mere queued-as-text never produces: /clear shows the fresh-session
    # welcome banner; /compact shows its compaction/summary state. This marker
    # is the verification — read the pane back and look for it.
    # The marker must match only what RUNNING the reset produces, never the
    # echoed/queued command text — else a reset swallowed as text would falsely
    # verify. /clear's fresh banner and /compact's capital-C "Compacting"/
    # "Compacted" never appear in the literal "/clear"/"/compact" a queued
    # message shows.
    case "$RESET" in
      clear)   REGISTERED_RE='Welcome back|Tips for getting started|Claude Code v[0-9]' ;;
      compact) REGISTERED_RE='Compacting|Compacted' ;;
    esac

    reset_registered() {
      tmux capture-pane -t "$TARGET" -p | grep -qE "$REGISTERED_RE"
    }

    log "waking; target=$TARGET reset=/$RESET msgfile=$MSGFILE"
    sleep "$BOTTLE_DELAY_SECONDS"

    # [LAW:dataflow-not-control-flow] act-and-verify, not predict-then-hope. Each
    # attempt: Escape (cancels any in-flight response AND clears queued text — a
    # harmless no-op on an idle pane), then type the reset and submit it, then
    # READ THE PANE to confirm it registered. A reset typed while the pane is
    # busy is swallowed as queued text and never runs; reading back is the only
    # way to know it took. Loop until verified or attempts exhausted.
    registered=1
    for attempt in $(seq 1 "$MAX_RESET_ATTEMPTS"); do
      log "reset attempt $attempt/$MAX_RESET_ATTEMPTS: Escape + /$RESET"
      tmux send-keys -t "$TARGET" Escape
      sleep 1
      tmux send-keys -t "$TARGET" "/$RESET"
      sleep 0.5
      tmux send-keys -t "$TARGET" Enter
      sleep "$SETTLE"
      if reset_registered; then registered=0; log "/$RESET registered"; break; fi
      log "/$RESET did NOT register; retrying"
    done

    # [LAW:types-are-the-program] the paste is structurally downstream of a
    # verified reset — it lives only on the registered branch, so the message
    # CANNOT be sent into an un-reset session. The other branch never pastes;
    # it surfaces the misfire instead (the session is intact, since the reset
    # never ran, so the diagnostic is visible right where it happened).
    if [[ "$registered" -eq 0 ]]; then
      log "pasting message"
      tmux load-buffer -b "$BUFFER" "$MSGFILE"
      tmux paste-buffer -b "$BUFFER" -t "$TARGET" -p
      sleep 0.5
      tmux send-keys -t "$TARGET" Enter
      log "done"
    else
      log "MISFIRE: /$RESET never registered after $MAX_RESET_ATTEMPTS attempts; message NOT sent"
      # Surface it in the still-intact session, unsubmitted, so a human sees it.
      printf 'message-in-a-bottle MISFIRE — /%s never registered after %d attempts; held message NOT sent. log: see worker output' \
        "$RESET" "$MAX_RESET_ATTEMPTS" | tmux load-buffer -b "$BUFFER" -
      tmux paste-buffer -b "$BUFFER" -t "$TARGET" -p
    fi
    ;;
esac
