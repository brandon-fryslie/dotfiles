#!/usr/bin/env bash
set -euo pipefail

# [LAW:decomposition] This part does ONE thing: faithfully move bytes between the
# controlling agent and another harness's tmux pane — injecting input (`send`,
# `keys`) or capturing what's there (`list`, `context`, `read-screen`). A dumb,
# faithful courier in both directions. It knows NOTHING about which harness is
# running, which commands exist, or whether the pane is idle; that judgment lives
# with the controlling agent reading references/<harness>.md. The script gathers
# raw observations and delivers raw input — interpreting either is the agent's job.
#
# [FRAMING:representation] Unlike tmux-talk, there is no From:/To-reply: envelope.
# The receiver here is the harness's CLI parser, not a human reader — the bytes
# delivered must be EXACTLY the command (`/clear`) or it won't be recognized.
# Wrapping anything around it would corrupt the command. "No wrapper" is the point.

USAGE="tmux-command — inject built-in slash commands / keystrokes into another agent harness's pane

Subcommands:
  list                           List all tmux panes with session:window.pane address and running command
  context <target> [lines]       Gather before acting: the target's id line (cmd/title) + its current screen
  send  <target> <command...>    Type a literal command line into the pane, then submit it (no envelope)
  keys  <target> <key...>        Send raw tmux key names (Enter, Down, Up, Escape, BSpace, …) — drive pickers
  read-screen <target> [lines]   Capture pane content (default: 200 lines) — re-check / verify a command's effect

target: session:window.pane, or shorthand — :win.pane / :win / .pane (same session/window),
  :self (own pane), and window-by-name (dotfiles:orca). See tmux-shared/bin/tmux-resolve.

The command set differs per harness (claude code, codex, opencode). Run 'list' to find the
target and its running command, then read the matching references/<harness>.md before sending."

# [LAW:single-enforcer] Addressing is not defined here. Every target — full or
# shorthand (`:3`, `.2`, `:self`, `dotfiles:orca`) — is resolved to a canonical,
# verified session:window.pane by the one shared resolver, which rejects a bad or
# ambiguous target loudly [LAW:no-silent-failure]. Resolving up front means no
# verb below ever touches an unresolved or nonexistent pane.
RESOLVE="$(cd "$(dirname "$0")" && pwd)/../../tmux-shared/bin/tmux-resolve"
resolve_target() { "$RESOLVE" "$1"; }

CMD="${1:-}"

case "$CMD" in

  list)
    tmux list-panes -a -F "#{session_name}:#{window_index}.#{pane_index}  cmd=#{pane_current_command}  title=#{pane_title}"
    ;;

  context)
    TARGET="${2:-}"
    LINES="${3:-200}"
    if [[ -z "$TARGET" ]]; then
      echo "Usage: tmux-command context <target> [lines]" >&2
      exit 1
    fi
    TARGET="$(resolve_target "$TARGET")" || exit 1

    # [LAW:composability] One call returns everything needed to choose a command,
    # asking nothing: the pane's identity (cmd=/title= name the harness) and its
    # live screen (idle vs generating, and which screen is up). The agent reads
    # this, decides, then sends — so SKILL.md need not script the gather by hand.
    # display-message -t resolves the EXACT pane; list-panes -t widens to the
    # whole window, so it is the wrong verb for a single-pane identity line.
    tmux display-message -p -t "$TARGET" "#{session_name}:#{window_index}.#{pane_index}  cmd=#{pane_current_command}  title=#{pane_title}"
    echo "---"
    tmux capture-pane -t "$TARGET" -p -S -"$LINES"
    ;;

  send)
    TARGET="${2:-}"
    # Everything after the target is the command line, so an unquoted command with
    # arguments (e.g. `send work:0.0 /model opus`) isn't truncated to its first word.
    COMMAND="${*:3}"
    if [[ -z "$TARGET" || -z "$COMMAND" ]]; then
      echo "Usage: tmux-command send <target> <command...>" >&2
      exit 1
    fi
    TARGET="$(resolve_target "$TARGET")" || exit 1

    # [LAW:no-ambient-temporal-coupling] The two-step send — literal text, settle,
    # then a SEPARATE Enter — is the proven timing contract. A combined
    # `send-keys ... Enter` races the harness's input handler and the Enter is
    # silently dropped. `-l` sends the text verbatim so the leading `/` and any
    # special characters reach the parser unmangled.
    tmux send-keys -t "$TARGET" -l "$COMMAND"
    sleep 1
    tmux send-keys -t "$TARGET" Enter
    ;;

  keys)
    TARGET="${2:-}"
    if [[ -z "$TARGET" || -z "${3:-}" ]]; then
      echo "Usage: tmux-command keys <target> <key...>   (e.g. keys work:0.0 Down Down Enter)" >&2
      exit 1
    fi
    TARGET="$(resolve_target "$TARGET")" || exit 1

    # [LAW:dataflow-not-control-flow] Key names flow straight through to tmux as
    # values; this verb adds no interpretation. It exists because many commands
    # open interactive pickers (model/permissions/resume) that only raw keys drive.
    tmux send-keys -t "$TARGET" "${@:3}"
    ;;

  read-screen)
    TARGET="${2:-}"
    LINES="${3:-200}"
    if [[ -z "$TARGET" ]]; then
      echo "Usage: tmux-command read-screen <target> [lines]" >&2
      exit 1
    fi
    TARGET="$(resolve_target "$TARGET")" || exit 1
    tmux capture-pane -t "$TARGET" -p -S -"$LINES"
    ;;

  *)
    echo "$USAGE" >&2
    exit 1
    ;;

esac
